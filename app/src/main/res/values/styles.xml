<resources>

    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/text_on_dark</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryLight</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/ScActivityAnimation</item>
    </style>

    <style name="BottomNavigationTheme" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
    </style>

    <style name="BottomNavigationViewTextAppearance" parent="@style/TextAppearance.AppCompat.Caption">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="BottomNavigationViewTextAppearance.Active" parent="@style/TextAppearance.AppCompat.Caption">
        <item name="android:textSize">11sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="SwitchTheme" parent="Theme.AppCompat.Light">
        <item name="colorControlActivated">@color/colorAccent</item>
        <item name="colorSwitchThumbNormal">#E0E0E0</item>
        <item name="android:colorForeground">#3A3A3A</item>
    </style>

    <style name="ScActivityAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/page_slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/page_slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/page_slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/page_slide_out_right</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.Hero.Title" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">22sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Hero.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_on_dark_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.Section.Header" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Toolbar.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">18sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

</resources>
