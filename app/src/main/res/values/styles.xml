<resources>

    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryLight</item>
        <item name="colorOnPrimaryContainer">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorTertiary">@color/status_ok</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/gradient_start</item>
        <item name="android:windowAnimationStyle">@style/ScActivityAnimation</item>
    </style>

    <style name="BottomNavigationTheme" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="android:background">@color/surface</item>
    </style>

    <style name="BottomNavigationViewTextAppearance" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
    </style>

    <style name="BottomNavigationViewTextAppearance.Active" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <!-- Pink accent on toggle track when ON -->
    <style name="SwitchTheme" parent="Theme.MaterialComponents.Light">
        <item name="colorControlActivated">@color/colorAccent</item>
        <item name="colorSwitchThumbNormal">#E8E8F0</item>
        <item name="android:colorForeground">#44444A</item>
    </style>

    <style name="ScActivityAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/page_slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/page_slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/page_slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/page_slide_out_right</item>
    </style>

</resources>
