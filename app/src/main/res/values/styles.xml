<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="android:windowAnimationStyle">@style/ScActivityAnimation</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>
    </style>

    <style name="BottomNavigationTheme" parent="Widget.Material3.BottomNavigationView">
        <item name="colorPrimary">@color/colorPrimary</item>
    </style>

    <style name="BottomNavigationViewTextAppearance" parent="@style/TextAppearance.AppCompat.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/gray</item>
    </style>

    <style name="BottomNavigationViewTextAppearance.Active" parent="@style/TextAppearance.AppCompat.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <style name="SwitchTheme" parent="Theme.AppCompat.Light">
        <!-- active thumb & track color (30% transparency) -->
        <item name="colorControlActivated">#FFEB3B</item>

        <!-- inactive thumb color -->
        <item name="colorSwitchThumbNormal">#f1f1f1</item>

        <!-- inactive track color (30% transparency) -->
        <item name="android:colorForeground">#221f1f</item>
    </style>

    <style name="ScActivityAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/page_slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/page_slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/page_slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/page_slide_out_right</item>
    </style>

    <style name="Widget.App.Toolbar" parent="">
        <item name="android:background">@color/colorPrimary</item>
        <item name="android:elevation">4dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="Widget.App.TimeButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minWidth">48dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

</resources>
