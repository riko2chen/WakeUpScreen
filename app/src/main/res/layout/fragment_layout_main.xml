<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HERO SECTION ===== -->
            <FrameLayout
                android:id="@+id/cl_header"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@drawable/bg_hero_gradient">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp">

                    <TextView
                        android:id="@+id/tv_tips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/tip_desc_time_cost"
                        style="@style/TextAppearance.Hero.Subtitle" />

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/already_close"
                        style="@style/TextAppearance.Hero.Title" />

                    <!-- Toggle with glow ring -->
                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">

                        <View
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_toggle_glow" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/btn_control"
                            android:layout_width="wrap_content"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            android:theme="@style/SwitchTheme"
                            tools:checked="true" />
                    </FrameLayout>

                </LinearLayout>
            </FrameLayout>

            <!-- ===== STATUS CARDS ===== -->
            <LinearLayout
                android:id="@+id/ll_middle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:clipToPadding="false">

                <com.symeonchen.uicomponent.views.StatusItem
                    android:id="@+id/main_item_service"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_card"
                    android:elevation="2dp" />

                <com.symeonchen.uicomponent.views.StatusItem
                    android:id="@+id/main_item_permission_notification"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_card"
                    android:elevation="2dp" />

                <com.symeonchen.uicomponent.views.StatusItem
                    android:id="@+id/main_item_battery_saver"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_card"
                    android:elevation="2dp" />

                <com.symeonchen.uicomponent.views.StatusItem
                    android:id="@+id/main_item_send_notification"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_card"
                    android:elevation="2dp" />

            </LinearLayout>

            <!-- ===== NOTICE CARD ===== -->
            <TextView
                android:id="@+id/tv_reset_application"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_notice_card"
                android:drawablePadding="8dp"
                android:padding="14dp"
                android:text="@string/still_have_problem"
                android:textColor="@color/accent_amber"
                android:textSize="13sp"
                android:visibility="invisible"
                tools:visibility="visible" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
