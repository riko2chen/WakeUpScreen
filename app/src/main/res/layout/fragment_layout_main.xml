<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ===== HERO ===== -->
        <FrameLayout
            android:id="@+id/cl_header"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/bg_hero_gradient">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="32dp">

                <!-- Decorative app label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.15"
                    android:text="@string/app_name"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />

                <!-- Main status -->
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="@string/already_close"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Toggle in frosted pill -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_toggle_pill"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="10dp">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/btn_control"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:theme="@style/SwitchTheme"
                        tools:checked="true" />
                </LinearLayout>

                <!-- Tips -->
                <TextView
                    android:id="@+id/tv_tips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/tip_desc_time_cost"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp" />

            </LinearLayout>
        </FrameLayout>

        <!-- ===== STATUS CARDS ===== -->
        <LinearLayout
            android:id="@+id/ll_middle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="false"
                android:focusable="false"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <com.symeonchen.uicomponent.views.StatusItem
                    android:id="@+id/main_item_service"
                    android:layout_width="match_parent"
                    android:layout_height="72dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="false"
                android:focusable="false"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <com.symeonchen.uicomponent.views.StatusItem
                    android:id="@+id/main_item_permission_notification"
                    android:layout_width="match_parent"
                    android:layout_height="72dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="false"
                android:focusable="false"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <com.symeonchen.uicomponent.views.StatusItem
                    android:id="@+id/main_item_battery_saver"
                    android:layout_width="match_parent"
                    android:layout_height="72dp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="false"
                android:focusable="false"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <com.symeonchen.uicomponent.views.StatusItem
                    android:id="@+id/main_item_send_notification"
                    android:layout_width="match_parent"
                    android:layout_height="72dp" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ===== NOTICE ===== -->
        <TextView
            android:id="@+id/tv_reset_application"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_notice_card"
            android:padding="14dp"
            android:text="@string/still_have_problem"
            android:textColor="@color/amber"
            android:textSize="13sp"
            android:visibility="invisible"
            tools:visibility="visible" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
